# Standalone/local API mode.
# Copy to .env when running the FastAPI service outside the VPS Docker stack.

ENVIRONMENT=development
WEB_ORIGIN=http://localhost:3001
DATABASE_URL=sqlite:///./services/api/local.db
SECRET_KEY=dev-only-change-me

# Used when ENVIRONMENT=production and seeded local users are hidden.
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=ChangeMe123!
BOOTSTRAP_ADMIN_NAME=Institution Admin
BOOTSTRAP_INSTITUTION_NAME=Nova Learning Institution

# Optional session duration.
ACCESS_TOKEN_MINUTES=720
