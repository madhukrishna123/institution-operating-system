# Standalone web mode.
# Copy to apps/web/.env.local for local Next.js development.

# Local default: keep frontend calls on /api and let next.config.ts rewrite to FastAPI.
NEXT_PUBLIC_API_BASE_URL=/api
API_REWRITE_TARGET=http://127.0.0.1:8000

# For Vercel web + external API, use one of these patterns:
# 1. Direct public API URL:
# NEXT_PUBLIC_API_BASE_URL=https://your-api-host.example.com/api
#
# 2. Same frontend /api path with a Vercel rewrite:
# NEXT_PUBLIC_API_BASE_URL=/api
# API_REWRITE_TARGET=https://your-api-host.example.com
